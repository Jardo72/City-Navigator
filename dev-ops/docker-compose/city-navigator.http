# City Navigator - REST Client Collection
# VS Code REST Client extension (humao.rest-client)
#
# Usage:
#   - Click "Send Request" above any ### block to execute it
#   - Variables defined with @name can be updated and are used with {{name}}
#   - Capture response values with @varname = {{response.body.$.field}} after a request
#   - Run POST/PUT requests first to capture UUIDs for subsequent requests

###############################################################################
# Variables
###############################################################################

@master_data_base = http://localhost/city-navigator/api/master-data
@query_base       = http://localhost/city-navigator/api/query

# Fill in after running POST /means-of-transport
@mot_uuid = replace-with-uuid-from-post-response

# Fill in after running POST /station
@station_uuid = replace-with-uuid-from-post-response

# Fill in after running POST /line
@line_uuid = replace-with-uuid-from-post-response


###############################################################################
# MASTER DATA SERVICE
###############################################################################


# ── Means of Transport ───────────────────────────────────────────────────────

### Get all means of transport
GET {{master_data_base}}/means-of-transport

###

### Get one means of transport by UUID
GET {{master_data_base}}/means-of-transport/{{mot_uuid}}

###

### Create a means of transport
# @name createMoT
POST {{master_data_base}}/means-of-transport
Content-Type: application/json

{
  "identifier": "Monorail",
  "presentation_color": "#FF6600"
}

###

### Update a means of transport
PUT {{master_data_base}}/means-of-transport/{{mot_uuid}}
Content-Type: application/json

{
  "identifier": "Monorail Express",
  "presentation_color": "#FF8800"
}

###

### Delete a means of transport
DELETE {{master_data_base}}/means-of-transport/{{mot_uuid}}


# ── Stations ─────────────────────────────────────────────────────────────────

### Get all stations
GET {{master_data_base}}/stations

###

### Get one station by UUID
GET {{master_data_base}}/station/{{station_uuid}}

###

### Create a station
# @name createStation
POST {{master_data_base}}/station
Content-Type: application/json

{
  "name": "Testbahnhof"
}

###

### Update a station
PUT {{master_data_base}}/station/{{station_uuid}}
Content-Type: application/json

{
  "name": "Testbahnhof Nord"
}

###

### Delete a station
DELETE {{master_data_base}}/station/{{station_uuid}}


# ── Lines ─────────────────────────────────────────────────────────────────────

### Get all lines
GET {{master_data_base}}/lines

###

### Get one line by UUID
GET {{master_data_base}}/line/{{line_uuid}}

###

### Create a line
# Requires valid UUIDs for means_of_transport and stations.
# Run GET /means-of-transport and GET /stations first, then substitute below.
# @name createLine
POST {{master_data_base}}/line
Content-Type: application/json

{
  "label": "TX",
  "means_of_transport_uuid": "replace-with-mot-uuid",
  "terminal_stop_one_uuid": "replace-with-station-a-uuid",
  "terminal_stop_two_uuid": "replace-with-station-c-uuid",
  "direction_one_itinerary": [
    { "station_uuid": "replace-with-station-a-uuid", "point_in_time_minutes": 0 },
    { "station_uuid": "replace-with-station-b-uuid", "point_in_time_minutes": 5 },
    { "station_uuid": "replace-with-station-c-uuid", "point_in_time_minutes": 10 }
  ],
  "direction_two_itinerary": [
    { "station_uuid": "replace-with-station-c-uuid", "point_in_time_minutes": 0 },
    { "station_uuid": "replace-with-station-b-uuid", "point_in_time_minutes": 5 },
    { "station_uuid": "replace-with-station-a-uuid", "point_in_time_minutes": 10 }
  ]
}

###

### Update a line (same structure as POST)
PUT {{master_data_base}}/line/{{line_uuid}}
Content-Type: application/json

{
  "label": "TX",
  "means_of_transport_uuid": "replace-with-mot-uuid",
  "terminal_stop_one_uuid": "replace-with-station-a-uuid",
  "terminal_stop_two_uuid": "replace-with-station-c-uuid",
  "direction_one_itinerary": [
    { "station_uuid": "replace-with-station-a-uuid", "point_in_time_minutes": 0 },
    { "station_uuid": "replace-with-station-b-uuid", "point_in_time_minutes": 6 },
    { "station_uuid": "replace-with-station-c-uuid", "point_in_time_minutes": 12 }
  ],
  "direction_two_itinerary": [
    { "station_uuid": "replace-with-station-c-uuid", "point_in_time_minutes": 0 },
    { "station_uuid": "replace-with-station-b-uuid", "point_in_time_minutes": 6 },
    { "station_uuid": "replace-with-station-a-uuid", "point_in_time_minutes": 12 }
  ]
}

###

### Delete a line
DELETE {{master_data_base}}/line/{{line_uuid}}


###############################################################################
# QUERY SERVICE
###############################################################################


# ── Means of Transport ───────────────────────────────────────────────────────

### Get all means of transport (with their lines)
GET {{query_base}}/means-of-transport


# ── Stations ─────────────────────────────────────────────────────────────────

### Get all stations (with lines served)
GET {{query_base}}/stations

###

### Get stations with wildcard filter
GET {{query_base}}/stations?filter=Karl*

###

### Get stations with wildcard filter (mid-word)
GET {{query_base}}/stations?filter=*platz*

###

### Get one station by name
GET {{query_base}}/station?name=Karlsplatz

###

### Get one station by name (multi-word)
GET {{query_base}}/station?name=Westbahnhof


# ── Lines ─────────────────────────────────────────────────────────────────────

### Get all lines
GET {{query_base}}/lines

###

### Get lines filtered by means of transport
GET {{query_base}}/lines?means_of_transport=U-Bahn

###

### Get lines filtered by means of transport (S-Bahn)
GET {{query_base}}/lines?means_of_transport=S-Bahn

###

### Get one line by label (with full itinerary and transfer info)
GET {{query_base}}/line?label=U1

###

### Get one line by label
GET {{query_base}}/line?label=U3


# ── Journey Planner ───────────────────────────────────────────────────────────

### Direct connection (single line, two stops)
GET {{query_base}}/journey-plan?start=Karlsplatz&destination=Stephansplatz

###

### Multi-stop journey (same line)
GET {{query_base}}/journey-plan?start=Westbahnhof&destination=Stephansplatz

###

### Journey requiring a transfer
GET {{query_base}}/journey-plan?start=Praterstern&destination=Karlsplatz

###

### Journey across town
GET {{query_base}}/journey-plan?start=Simmering&destination=Westbahnhof

###

### Journey - unknown station (expect 404)
GET {{query_base}}/journey-plan?start=Atlantis&destination=Karlsplatz
